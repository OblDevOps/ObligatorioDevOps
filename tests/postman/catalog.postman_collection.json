{
  "info": {
    "name": "Catalog API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Health check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Body is OK', function () {",
              "  pm.expect(pm.response.text()).to.equal('OK');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "List products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "  pm.expect(body.length).to.be.above(0);",
              "});",
              "pm.test('Products have required fields', function () {",
              "  var product = pm.response.json()[0];",
              "  pm.expect(product).to.have.property('id');",
              "  pm.expect(product).to.have.property('name');",
              "  pm.expect(product).to.have.property('price');",
              "});",
              "var firstId = pm.response.json()[0].id;",
              "pm.collectionVariables.set('productId', firstId);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/products"
      }
    },
    {
      "name": "Get product by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Product has correct ID', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('id');",
              "  pm.expect(body.id).to.equal(pm.collectionVariables.get('productId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/products/{{productId}}"
      }
    },
    {
      "name": "Get product by ID - not found",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/products/non-existent-id"
      }
    },
    {
      "name": "List tags",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/tags"
      }
    },
    {
      "name": "Catalog size",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Size is a positive number', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('size');",
              "  pm.expect(body.size).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/catalog/size"
      }
    }
  ]
}
